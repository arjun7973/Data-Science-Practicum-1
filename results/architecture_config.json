{
  "model_name": "EfficientNetB2_SkinLesion",
  "base_model": "EfficientNetB2",
  "input_shape": [
    256,
    256,
    3
  ],
  "num_classes": 8,
  "class_names": [
    "AKIEC",
    "BCC",
    "BKL",
    "DF",
    "MEL",
    "NV",
    "VASC"
  ],
  "batch_size": 64,
  "augmentation": {
    "rotation_factor": 0.15,
    "translation_height": 0.1,
    "translation_width": 0.1,
    "flip": true,
    "contrast_factor": 0.1
  },
  "architecture": {
    "base_model": "EfficientNetB2",
    "pooling": "GlobalAveragePooling2D",
    "dropout_rate": 0.2,
    "output_activation": "softmax"
  },
  "training_phase_1": {
    "learning_rate": 0.01,
    "epochs": 20,
    "freeze_base": true,
    "description": "Feature extraction - training classification head only"
  },
  "training_phase_2": {
    "learning_rate": 0.0001,
    "epochs": 30,
    "freeze_base": false,
    "description": "Fine-tuning - training all layers"
  },
  "callbacks": [
    "EarlyStopping",
    "ModelCheckpoint",
    "ReduceLROnPlateau"
  ]
}